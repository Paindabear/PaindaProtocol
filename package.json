{
  "name": "painda-protocol-monorepo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=apps/web",
    "build:core": "npm run build --workspace=packages/core",
    "build:web": "npm run build --workspace=apps/web",
    "bench:server": "npm run start --workspace=apps/bench-server"
  }
}
