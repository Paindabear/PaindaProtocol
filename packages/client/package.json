{
  "name": "@painda/client",
  "version": "0.1.7",
  "description": "Lightweight, browser-friendly client for PaindaProtocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/index.browser.js"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist",
    "esbuild.config.js"
  ],
  "scripts": {
    "build": "tsc && npm run build:browser",
    "build:browser": "node esbuild.config.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@painda/core": "^0.1.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@painda/gaming": "*"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@painda/gaming": { "optional": true }
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5"
  },
  "author": "Painda",
  "license": "MIT"
}
